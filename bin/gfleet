#!/usr/bin/env bash
# gfleet — graphify-fleet: orchestrate graphify across multiple related repos.
# See README.md for usage.
set -euo pipefail

GFLEET_VERSION="0.1.0"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
TEMPLATES_DIR="$ROOT_DIR/templates"

GRAPHIFY_DIR="${GRAPHIFY_DIR:-$HOME/.graphify}"
GROUPS_DIR="$GRAPHIFY_DIR/groups"
LOCAL_BIN="$HOME/.local/bin"

# ----- platform -----
case "$(uname -s)" in
    Darwin)  PLATFORM="darwin" ;;
    Linux)   PLATFORM="linux" ;;
    *)       PLATFORM="unknown" ;;
esac

# ----- ui -----
c_red()   { printf '\033[31m%s\033[0m\n' "$*"; }
c_green() { printf '\033[32m%s\033[0m\n' "$*"; }
c_yel()   { printf '\033[33m%s\033[0m\n' "$*"; }
c_dim()   { printf '\033[2m%s\033[0m\n' "$*"; }
say()     { printf '%s\n' "$*"; }
hr()      { printf '\033[2m─────────────────────────────────────────────\033[0m\n'; }
die()     { c_red "✗ $*"; exit 1; }
ok()      { c_green "✓ $*"; }
warn()    { c_yel  "! $*"; }
info()    { say "  $*"; }

# ----- prereqs -----
need() { command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"; }

require_prereqs() {
    need bash
    need jq
    need git
    need uv  || die "uv is required. install: curl -LsSf https://astral.sh/uv/install.sh | sh"
}

ensure_graphify() {
    if ! command -v graphify >/dev/null 2>&1; then
        info "installing graphifyy via uv (with mcp + watchdog extras)..."
        uv tool install graphifyy --with mcp --with watchdog >/dev/null 2>&1 || \
        uv tool install graphifyy --with mcp --with watchdog --reinstall >/dev/null
    else
        # ensure mcp + watchdog are present
        local py
        py="$(graphify_python)"
        if ! "$py" -c "import mcp, watchdog" 2>/dev/null; then
            info "adding mcp + watchdog extras to graphifyy..."
            uv tool install graphifyy --with mcp --with watchdog --reinstall >/dev/null
        fi
    fi
}

graphify_python() {
    # interpreter that has graphify importable
    local bin
    bin="$(command -v graphify)"
    head -1 "$bin" | sed 's|^#!\s*||' | awk '{print $1}'
}

# ----- config parsing -----
expand_path() {
    # ~/foo -> $HOME/foo  (also handles bare ~)
    local p="$1"
    if [ "$p" = "~" ]; then
        printf '%s\n' "$HOME"
    elif [[ "$p" == "~/"* ]]; then
        printf '%s\n' "$HOME/${p:2}"
    else
        printf '%s\n' "$p"
    fi
}

load_config() {
    local config="$1"
    [ -f "$config" ] || die "config not found: $config"
    GROUP="$(jq -r '.group' "$config")"
    [ "$GROUP" != "null" ] && [ -n "$GROUP" ] || die "config missing 'group'"
    GROUP_GRAPH="$GROUPS_DIR/$GROUP.json"

    # arrays
    REPO_PATHS=()
    REPO_SLUGS=()
    REPO_STACKS=()
    while IFS=$'\t' read -r p s st; do
        REPO_PATHS+=("$(expand_path "$p")")
        REPO_SLUGS+=("$s")
        REPO_STACKS+=("${st:-generic}")
    done < <(jq -r '.repos[] | [.path, .slug, (.stack // "generic")] | @tsv' "$config")

    [ "${#REPO_PATHS[@]}" -gt 0 ] || die "config has no repos"

    OPT_WIKI_GITIGNORED="$(jq -r '.options.wiki_gitignored // true'  "$config")"
    OPT_WATCHERS="$(       jq -r '.options.watchers        // true'  "$config")"
    OPT_WINDSURF="$(       jq -r '.options.windsurf        // true'  "$config")"
    OPT_CLAUDE="$(         jq -r '.options.claude_code     // true'  "$config")"
}

# ----- per-repo install pieces -----
write_graphifyignore() {
    local repo="$1" stack="$2"
    local tpl="$TEMPLATES_DIR/graphifyignore-${stack}.txt"
    [ -f "$tpl" ] || tpl="$TEMPLATES_DIR/graphifyignore-generic.txt"
    if [ ! -f "$repo/.graphifyignore" ]; then
        cp "$tpl" "$repo/.graphifyignore"
        info ".graphifyignore written ($stack template)"
    else
        info ".graphifyignore already exists, leaving as-is"
    fi
}

update_gitignore() {
    local repo="$1"
    local f="$repo/.gitignore"
    touch "$f"
    if grep -q "^graphify-out/wiki/" "$f" 2>/dev/null; then
        return 0
    fi
    {
        printf '\n# graphify-fleet\n'
        printf 'graphify-out/wiki/\n'
        printf 'graphify-out/manifest.json\n'
        printf 'graphify-out/cost.json\n'
        printf 'graphify-out/cache/\n'
    } >> "$f"
    info ".gitignore updated"
}

write_mcp_json() {
    # writes (or merges) graphify entry into <repo>/.mcp.json pointing at the
    # group-scoped merged graph.
    local repo="$1"
    local f="$repo/.mcp.json"
    local py; py="$(graphify_python)"
    local server
    server="$(jq -n --arg cmd "$py" --arg graph "$GROUP_GRAPH" \
        '{command:$cmd, args:["-m","graphify.serve",$graph]}')"

    if [ -f "$f" ]; then
        # merge / overwrite the graphify entry only
        local tmp; tmp="$(mktemp)"
        jq --argjson srv "$server" '.mcpServers.graphify = $srv' "$f" > "$tmp"
        mv "$tmp" "$f"
    else
        jq -n --argjson srv "$server" '{mcpServers:{graphify:$srv}}' > "$f"
    fi
    info ".mcp.json: graphify -> $GROUP_GRAPH"
}

write_windsurf_files() {
    local repo="$1"
    mkdir -p "$repo/.windsurf/workflows"
    cp "$TEMPLATES_DIR/windsurf-workflow.md" "$repo/.windsurf/workflows/graphify.md"

    local rules="$repo/.windsurfrules"
    if ! grep -q "^## graphify" "$rules" 2>/dev/null; then
        cat >> "$rules" <<EOF

## graphify

This project is part of the **$GROUP** group, with a merged knowledge graph at $GROUP_GRAPH.

Rules:
- Before answering architecture or codebase questions, read graphify-out/GRAPH_REPORT.md for god nodes and community structure
- If graphify-out/wiki/index.md exists, navigate it instead of reading raw files
- For cross-repo questions, query the graphify MCP server (group: $GROUP) which exposes the merged graph
- After modifying code in this session, run \`graphify update .\` to keep the graph current
EOF
    fi
    info "windsurf workflow + rules written"
}

install_claude_skill() {
    local repo="$1"
    ( cd "$repo" && graphify claude install >/dev/null 2>&1 ) && \
        info "claude skill installed (CLAUDE.md + PreToolUse hook)" || \
        warn "graphify claude install failed (continuing)"
}

build_initial_graph() {
    local repo="$1" slug="$2"
    if [ ! -f "$repo/graphify-out/graph.json" ]; then
        info "building initial AST graph (this can take 30-90s)..."
        ( cd "$repo" && graphify update . >/dev/null 2>&1 ) || warn "initial graphify update failed"
    fi
}

write_reregister_helper() {
    # one helper script per group; idempotent
    mkdir -p "$LOCAL_BIN" "$GROUPS_DIR"
    local helper="$LOCAL_BIN/graphify-fleet-merge-${GROUP}"
    {
        echo '#!/usr/bin/env bash'
        echo "# auto-generated by gfleet — re-merge group '$GROUP' after a repo rebuild"
        echo 'set -e'
        echo "GROUP_GRAPH=\"$GROUP_GRAPH\""
        echo 'GRAPHS=()'
        local i
        for i in "${!REPO_PATHS[@]}"; do
            echo "GRAPHS+=(\"${REPO_PATHS[$i]}/graphify-out/graph.json\")"
        done
        cat <<'EOSH'
# Wait briefly for the most recent rebuild to flush, then merge.
sleep 3
EXISTING=()
for g in "${GRAPHS[@]}"; do
    [ -f "$g" ] && EXISTING+=("$g")
done
if [ "${#EXISTING[@]}" -ge 2 ]; then
    graphify merge-graphs "${EXISTING[@]}" --out "$GROUP_GRAPH" >/dev/null 2>&1 || true
elif [ "${#EXISTING[@]}" -eq 1 ]; then
    cp "${EXISTING[0]}" "$GROUP_GRAPH"
fi
EOSH
    } > "$helper"
    chmod +x "$helper"
}

install_git_hooks() {
    local repo="$1" slug="$2"
    ( cd "$repo" && graphify hook install >/dev/null 2>&1 ) || warn "graphify hook install failed"

    local helper="$LOCAL_BIN/graphify-fleet-merge-${GROUP}"
    for hook in post-commit post-checkout; do
        local f="$repo/.git/hooks/$hook"
        [ -f "$f" ] || continue
        if ! grep -q "graphify-fleet-merge-${GROUP}" "$f" 2>/dev/null; then
            cat >> "$f" <<EOF

# gfleet-start ($GROUP)
nohup "$helper" > /dev/null 2>&1 &
disown 2>/dev/null || true
# gfleet-end ($GROUP)
EOF
        fi
    done
    info "git hooks installed (+ group remerge)"
}

# ----- watchers (per platform) -----
watcher_label() { printf 'ai.graphify.fleet.%s.%s' "$GROUP" "$1"; }

install_watcher_darwin() {
    local repo="$1" slug="$2"
    local label; label="$(watcher_label "$slug")"
    local plist="$HOME/Library/LaunchAgents/${label}.plist"
    local log_dir="$HOME/.cache/graphify-fleet/$GROUP"
    mkdir -p "$log_dir" "$HOME/Library/LaunchAgents"
    local graphify_bin; graphify_bin="$(command -v graphify)"
    cat > "$plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key><string>${label}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${graphify_bin}</string>
        <string>watch</string>
        <string>${repo}</string>
    </array>
    <key>WorkingDirectory</key><string>${repo}</string>
    <key>RunAtLoad</key><true/>
    <key>KeepAlive</key><true/>
    <key>StandardOutPath</key><string>${log_dir}/${slug}.log</string>
    <key>StandardErrorPath</key><string>${log_dir}/${slug}.err</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key><string>${HOME}/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
    <key>ThrottleInterval</key><integer>10</integer>
</dict>
</plist>
EOF
    launchctl unload "$plist" 2>/dev/null || true
    launchctl load   "$plist" 2>/dev/null || true
    info "watcher loaded: $label"
}

uninstall_watcher_darwin() {
    local slug="$1"
    local label; label="$(watcher_label "$slug")"
    local plist="$HOME/Library/LaunchAgents/${label}.plist"
    [ -f "$plist" ] || return 0
    launchctl unload "$plist" 2>/dev/null || true
    rm -f "$plist"
}

install_watcher_linux() {
    local repo="$1" slug="$2"
    local label; label="$(watcher_label "$slug")"
    local unit_dir="$HOME/.config/systemd/user"
    mkdir -p "$unit_dir"
    local graphify_bin; graphify_bin="$(command -v graphify)"
    cat > "$unit_dir/${label}.service" <<EOF
[Unit]
Description=graphify watcher ($GROUP/$slug)
After=default.target

[Service]
Type=simple
ExecStart=${graphify_bin} watch ${repo}
WorkingDirectory=${repo}
Restart=always
RestartSec=10
Environment=PATH=${HOME}/.local/bin:/usr/local/bin:/usr/bin:/bin

[Install]
WantedBy=default.target
EOF
    systemctl --user daemon-reload || true
    systemctl --user enable --now "${label}.service" 2>/dev/null || true
    info "watcher loaded: $label (systemd --user)"
}

uninstall_watcher_linux() {
    local slug="$1"
    local label; label="$(watcher_label "$slug")"
    systemctl --user disable --now "${label}.service" 2>/dev/null || true
    rm -f "$HOME/.config/systemd/user/${label}.service"
    systemctl --user daemon-reload 2>/dev/null || true
}

install_watcher() {
    case "$PLATFORM" in
        darwin) install_watcher_darwin "$@" ;;
        linux)  install_watcher_linux  "$@" ;;
        *)      warn "unsupported platform for watchers: $PLATFORM" ;;
    esac
}
uninstall_watcher() {
    case "$PLATFORM" in
        darwin) uninstall_watcher_darwin "$@" ;;
        linux)  uninstall_watcher_linux  "$@" ;;
    esac
}

watcher_status() {
    local slug="$1"
    local label; label="$(watcher_label "$slug")"
    case "$PLATFORM" in
        darwin)
            local row; row="$(launchctl list 2>/dev/null | awk -v L="$label" '$3==L {print $1, $2}')"
            if [ -z "$row" ]; then printf "%-40s %-8s %s\n" "$label" "-" "not loaded"
            else
                local pid="${row%% *}" exit_code="${row##* }"
                if [ "$pid" = "-" ]; then printf "%-40s %-8s %s\n" "$label" "-" "loaded (last exit $exit_code)"
                else printf "%-40s %-8s %s\n" "$label" "$pid" "running"
                fi
            fi
            ;;
        linux)
            if systemctl --user is-active --quiet "${label}.service"; then
                printf "%-40s %-8s %s\n" "$label" "-" "active"
            else
                printf "%-40s %-8s %s\n" "$label" "-" "inactive"
            fi
            ;;
    esac
}

# ----- legacy global graph cleanup -----
remove_from_legacy_global() {
    local slug="$1"
    graphify global remove "$slug" >/dev/null 2>&1 || true
}

# ====================================================================
# COMMANDS
# ====================================================================

cmd_doctor() {
    say "graphify-fleet $GFLEET_VERSION — doctor"
    hr
    say "platform: $PLATFORM"
    for c in bash jq git uv; do
        if command -v "$c" >/dev/null 2>&1; then ok "$c found"; else c_red "✗ $c missing"; fi
    done
    if command -v graphify >/dev/null 2>&1; then
        ok "graphify found ($(command -v graphify))"
        local py; py="$(graphify_python)"
        if "$py" -c "import mcp, watchdog" 2>/dev/null; then
            ok "graphify extras: mcp + watchdog"
        else
            warn "graphify is missing mcp / watchdog extras (gfleet install will fix)"
        fi
    else
        warn "graphify not installed yet (gfleet install will install it)"
    fi
}

cmd_install() {
    local config="$1"
    require_prereqs
    load_config "$config"
    ensure_graphify

    say "installing fleet group: $GROUP"
    say "merged graph -> $GROUP_GRAPH"
    hr

    write_reregister_helper

    local i
    for i in "${!REPO_PATHS[@]}"; do
        local repo="${REPO_PATHS[$i]}" slug="${REPO_SLUGS[$i]}" stack="${REPO_STACKS[$i]}"
        say ""
        c_green "▸ ${slug}  [${stack}]"
        info "$repo"
        [ -d "$repo/.git" ] || { warn "not a git repo, skipping: $repo"; continue; }

        write_graphifyignore "$repo" "$stack"
        update_gitignore     "$repo"
        build_initial_graph  "$repo" "$slug"
        write_mcp_json       "$repo"
        [ "$OPT_CLAUDE"   = "true" ] && install_claude_skill   "$repo"
        [ "$OPT_WINDSURF" = "true" ] && write_windsurf_files   "$repo"
        install_git_hooks    "$repo" "$slug"
        [ "$OPT_WATCHERS" = "true" ] && install_watcher        "$repo" "$slug"
        remove_from_legacy_global "$slug"
    done

    # initial merge
    say ""
    info "running initial group merge..."
    "$LOCAL_BIN/graphify-fleet-merge-${GROUP}"

    if [ "$OPT_WINDSURF" = "true" ]; then
        ensure_windsurf_skill
        ensure_windsurf_mcp
    fi

    say ""
    ok "group '$GROUP' installed."
    info "merged graph: $GROUP_GRAPH"
    info "watchers:     gfleet status $config"
}

ensure_windsurf_skill() {
    local dst="$HOME/.codeium/windsurf/skills/graphify/SKILL.md"
    [ -f "$dst" ] && return 0
    mkdir -p "$(dirname "$dst")"
    if command -v curl >/dev/null 2>&1; then
        curl -sLf "https://raw.githubusercontent.com/safishamsi/graphify/7c77a891939f889b99b48c0e8bc8cee5546a4c72/graphify/skill-windsurf.md" -o "$dst" \
            && info "windsurf SKILL.md installed (from PR #574)" \
            || warn "could not fetch windsurf SKILL.md (skipping)"
    fi
}

ensure_windsurf_mcp() {
    local f="$HOME/.codeium/windsurf/mcp_config.json"
    mkdir -p "$(dirname "$f")"
    [ -f "$f" ] || echo '{}' > "$f"
    local py; py="$(graphify_python)"
    local server
    server="$(jq -n --arg cmd "$py" --arg graph "$GROUP_GRAPH" \
        '{command:$cmd, args:["-m","graphify.serve",$graph]}')"
    local tmp; tmp="$(mktemp)"
    jq --arg name "graphify-${GROUP}" --argjson srv "$server" \
        '.mcpServers = ((.mcpServers // {}) + {($name): $srv})' "$f" > "$tmp"
    mv "$tmp" "$f"
    info "windsurf MCP entry: graphify-${GROUP}"
}

cmd_uninstall() {
    local config="$1"
    require_prereqs
    load_config "$config"
    say "uninstalling fleet group: $GROUP"
    hr

    local i
    for i in "${!REPO_PATHS[@]}"; do
        local repo="${REPO_PATHS[$i]}" slug="${REPO_SLUGS[$i]}"
        say ""
        c_yel "▸ ${slug}"
        [ -d "$repo/.git" ] || continue

        # remove gfleet hook block
        for hook in post-commit post-checkout; do
            local f="$repo/.git/hooks/$hook"
            [ -f "$f" ] || continue
            if grep -q "gfleet-start ($GROUP)" "$f" 2>/dev/null; then
                local tmp; tmp="$(mktemp)"
                awk -v g="$GROUP" '
                    $0 ~ "# gfleet-start \\("g"\\)" {skip=1; next}
                    $0 ~ "# gfleet-end \\("g"\\)"   {skip=0; next}
                    !skip {print}
                ' "$f" > "$tmp"
                mv "$tmp" "$f"
                chmod +x "$f"
                info "removed gfleet block from $hook"
            fi
        done

        # remove graphify entry from .mcp.json
        local mcp="$repo/.mcp.json"
        if [ -f "$mcp" ]; then
            local tmp; tmp="$(mktemp)"
            jq 'if .mcpServers.graphify then del(.mcpServers.graphify) else . end' "$mcp" > "$tmp"
            if [ "$(jq '.mcpServers // {} | length' "$tmp")" = "0" ]; then
                rm -f "$mcp"
                info ".mcp.json removed (was empty)"
            else
                mv "$tmp" "$mcp"
                info ".mcp.json: graphify entry removed"
            fi
        fi

        # remove windsurf workflow + rules block
        rm -f "$repo/.windsurf/workflows/graphify.md"
        rmdir "$repo/.windsurf/workflows" 2>/dev/null || true
        rmdir "$repo/.windsurf"           2>/dev/null || true
        if [ -f "$repo/.windsurfrules" ]; then
            local tmp; tmp="$(mktemp)"
            awk '/^## graphify$/ {skip=1; next} skip && /^## / {skip=0} !skip {print}' \
                "$repo/.windsurfrules" > "$tmp"
            mv "$tmp" "$repo/.windsurfrules"
        fi

        uninstall_watcher "$slug"
        info "watcher removed"
    done

    rm -f "$LOCAL_BIN/graphify-fleet-merge-${GROUP}"
    rm -f "$GROUP_GRAPH"

    # remove from windsurf global mcp
    local f="$HOME/.codeium/windsurf/mcp_config.json"
    if [ -f "$f" ]; then
        local tmp; tmp="$(mktemp)"
        jq --arg name "graphify-${GROUP}" 'if .mcpServers[$name] then del(.mcpServers[$name]) else . end' "$f" > "$tmp"
        mv "$tmp" "$f"
    fi

    say ""
    ok "group '$GROUP' uninstalled. Per-repo graphify-out/ left intact."
}

cmd_status() {
    local config="$1"
    load_config "$config"
    say "group: $GROUP"
    say "merged graph: $GROUP_GRAPH"
    if [ -f "$GROUP_GRAPH" ]; then
        local nodes edges
        nodes="$(jq '.nodes | length' "$GROUP_GRAPH" 2>/dev/null || echo '?')"
        edges="$(jq '.links | length' "$GROUP_GRAPH" 2>/dev/null || echo '?')"
        info "nodes: $nodes  edges: $edges"
    else
        warn "merged graph not found yet"
    fi
    hr
    printf "%-40s %-8s %s\n" "WATCHER" "PID" "STATUS"
    local i
    for i in "${!REPO_SLUGS[@]}"; do
        watcher_status "${REPO_SLUGS[$i]}"
    done
}

cmd_rebuild() {
    local config="$1" target="${2:-all}"
    load_config "$config"
    local i
    for i in "${!REPO_SLUGS[@]}"; do
        local slug="${REPO_SLUGS[$i]}"
        if [ "$target" != "all" ] && [ "$target" != "$slug" ]; then continue; fi
        local repo="${REPO_PATHS[$i]}"
        say "rebuilding $slug ($repo)..."
        ( cd "$repo" && GRAPHIFY_FORCE=1 graphify update . 2>&1 | tail -3 )
    done
    "$LOCAL_BIN/graphify-fleet-merge-${GROUP}"
    ok "rebuild complete"
}

cmd_remerge() {
    local config="$1"
    load_config "$config"
    "$LOCAL_BIN/graphify-fleet-merge-${GROUP}"
    ok "merged $GROUP_GRAPH"
}

cmd_start() {
    local config="$1"
    load_config "$config"
    local i
    for i in "${!REPO_SLUGS[@]}"; do install_watcher "${REPO_PATHS[$i]}" "${REPO_SLUGS[$i]}"; done
    ok "watchers loaded"
}
cmd_stop() {
    local config="$1"
    load_config "$config"
    local i
    for i in "${!REPO_SLUGS[@]}"; do uninstall_watcher "${REPO_SLUGS[$i]}"; info "stopped ${REPO_SLUGS[$i]}"; done
    ok "watchers stopped"
}
cmd_restart() { cmd_stop "$1"; cmd_start "$1"; }

usage() {
    cat <<EOF
gfleet $GFLEET_VERSION — orchestrate graphify across multiple related repos.

Usage:
  gfleet doctor                          check prerequisites
  gfleet install   <config.json>         set up fleet group (idempotent)
  gfleet uninstall <config.json>         remove watchers/hooks/configs
  gfleet status    <config.json>         watcher state + graph stats
  gfleet rebuild   <config.json> [slug]  force AST rebuild (use after deletions)
  gfleet remerge   <config.json>         re-merge group graph from current per-repo graphs
  gfleet start     <config.json>         load watchers
  gfleet stop      <config.json>         unload watchers
  gfleet restart   <config.json>
EOF
}

main() {
    local cmd="${1:-}"
    shift || true
    case "$cmd" in
        doctor)    cmd_doctor "$@" ;;
        install)   [ $# -ge 1 ] || die "usage: gfleet install <config.json>";    cmd_install   "$@" ;;
        uninstall) [ $# -ge 1 ] || die "usage: gfleet uninstall <config.json>"; cmd_uninstall "$@" ;;
        status)    [ $# -ge 1 ] || die "usage: gfleet status <config.json>";     cmd_status    "$@" ;;
        rebuild)   [ $# -ge 1 ] || die "usage: gfleet rebuild <config.json> [slug]"; cmd_rebuild "$@" ;;
        remerge)   [ $# -ge 1 ] || die "usage: gfleet remerge <config.json>";    cmd_remerge   "$@" ;;
        start)     [ $# -ge 1 ] || die "usage: gfleet start <config.json>";      cmd_start     "$@" ;;
        stop)      [ $# -ge 1 ] || die "usage: gfleet stop <config.json>";       cmd_stop      "$@" ;;
        restart)   [ $# -ge 1 ] || die "usage: gfleet restart <config.json>";    cmd_restart   "$@" ;;
        -h|--help|help|"") usage ;;
        *)         usage; exit 1 ;;
    esac
}

main "$@"
